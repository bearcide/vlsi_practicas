LIBRARY IEEE;
USE IEEE.STD_LOGIC_1164.ALL;

ENTITY deco IS
	PORT(ENTRADAS: IN INTEGER RANGE 0 TO 10;
				 SEG: OUT STD_LOGIC_VECTOR(0 TO 7));
END ENTITY;

ARCHITECTURE BEAS OF deco IS
BEGIN 
	WITH ENTRADAS SELECT
		SEG <= "00000011" WHEN 0,
				  X"9F" WHEN 1,
				  X"25" WHEN 2,
				  X"19" WHEN 3,
				  X"FF" WHEN OTHERS;
				  
				  
END BEAS;