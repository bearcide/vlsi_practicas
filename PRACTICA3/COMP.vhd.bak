LIBRARY IEEE;
USE IEEE.STD_LOGIC_1164.ALL;

ENTITY COMP IS
    PORT(CLK, RST: IN STD_LOGIC;
         CONT: IN INTEGER RANGE 0 TO 3;  -- Valor del contador (0-3 para 4 colores)
         CT: IN INTEGER RANGE 0 TO 3;    -- Valor de comparación (threshold)
         PWM: OUT STD_LOGIC);            -- Salida PWM
END ENTITY;

ARCHITECTURE BEAS OF COMP IS
    SIGNAL CONT_SAMPLED: INTEGER RANGE 0 TO 3;
    SIGNAL CT_SAMPLED: INTEGER RANGE 0 TO 3;
BEGIN 
    PROCESS(CLK, RST)
    BEGIN
        IF RST = '1' THEN
            PWM <= '0';
            CONT_SAMPLED <= 0;
            CT_SAMPLED <= 0;
        ELSIF RISING_EDGE(CLK) THEN
            -- Samplear las entradas en el flanco de reloj
            CONT_SAMPLED <= CONT;
            CT_SAMPLED <= CT;
            
            -- Comparar los valores sampleados
            IF CONT_SAMPLED < CT_SAMPLED THEN
                PWM <= '1';
            ELSE
                PWM <= '0';
            END IF;
        END IF;
    END PROCESS;
END BEAS;